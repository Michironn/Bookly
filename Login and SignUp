<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bookly – Log In</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet">
  <style>
    :root[data-theme="light"] {
      --bg: #f7f4ff;
      --surface: #ffffff;
      --surface2: #f0ebff;
      --border: #ddd5ff;
      --text: #1a0f3a;
      --text2: #5a4a8a;
      --text3: #9080b8;
      --accent: #6c3de8;
      --accent2: #a855f7;
      --glow: rgba(108, 61, 232, 0.20);
      --input-bg: #f7f4ff;
      --input-border: #d8cdff;
      --success: #38a169;
      --error: #e53e3e;
      --panel-grad: linear-gradient(160deg, #4a1fa8 0%, #7c3aed 45%, #c026d3 100%);
      --orb1: #6c3de8;
      --orb2: #a855f7;
      --nav-bg: rgba(247, 244, 255, 0.85);
    }

    :root[data-theme="dark"] {
      --bg: #0b0818;
      --surface: #170f30;
      --surface2: #1f1545;
      --border: #2e2260;
      --text: #ede8ff;
      --text2: #b0a0e0;
      --text3: #6a5898;
      --accent: #9b6ff5;
      --accent2: #c084fc;
      --glow: rgba(155, 111, 245, 0.28);
      --input-bg: #110c24;
      --input-border: #312060;
      --success: #68d391;
      --error: #fc8181;
      --panel-grad: linear-gradient(160deg, #1a0a40 0%, #3b1a8a 45%, #6c3de8 100%);
      --orb1: #4a1fa8;
      --orb2: #7c3aed;
      --nav-bg: rgba(11, 8, 24, 0.88);
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html,
    body {
      height: 100%;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      transition: background .4s, color .4s;
      overflow-x: hidden;
    }

    .ambient {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    .amb-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
      opacity: .14;
      transition: background .4s;
    }

    .amb-orb:nth-child(1) {
      width: 600px;
      height: 600px;
      top: -200px;
      right: -150px;
      background: var(--orb1);
      animation: driftA 12s ease-in-out infinite alternate;
    }

    .amb-orb:nth-child(2) {
      width: 400px;
      height: 400px;
      bottom: -120px;
      left: -100px;
      background: var(--orb2);
      animation: driftB 14s ease-in-out infinite alternate;
    }

    .amb-orb:nth-child(3) {
      width: 250px;
      height: 250px;
      top: 40%;
      left: 30%;
      background: #ec4899;
      opacity: .07;
      animation: driftA 18s ease-in-out infinite alternate-reverse;
    }

    @keyframes driftA {
      from {
        transform: translate(0, 0) scale(1);
      }

      to {
        transform: translate(40px, 30px) scale(1.1);
      }
    }

    @keyframes driftB {
      from {
        transform: translate(0, 0) scale(1);
      }

      to {
        transform: translate(-30px, 20px) scale(1.08);
      }
    }

    .topbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2.5rem;
      height: 62px;
      background: var(--nav-bg);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      transition: background .4s, border-color .4s;
    }

    .logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      font-weight: 900;
      color: var(--accent);
      text-decoration: none;
      letter-spacing: -.5px;
    }

    .logo span {
      color: var(--text);
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: .8rem;
    }

    .back-link {
      display: flex;
      align-items: center;
      gap: .3rem;
      font-size: .85rem;
      font-weight: 500;
      color: var(--text3);
      text-decoration: none;
      transition: color .2s;
    }

    .back-link:hover {
      color: var(--accent);
    }

    .theme-btn {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 1.5px solid var(--border);
      background: var(--surface2);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: var(--text2);
      transition: all .2s;
    }

    .theme-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .page {
      padding-top: 300px !important;
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 5rem 1.5rem 2rem;
      min-height: 100vh;
      position: relative;
      z-index: 1;
    }

    .auth-card {
      display: flex;
      width: 100%;
      max-width: 880px;
      border-radius: 28px;
      overflow: hidden;
      box-shadow: 0 32px 100px var(--glow), 0 4px 20px rgba(0, 0, 0, .12);
      animation: cardIn .6s cubic-bezier(.22, 1, .36, 1) both;
    }

    @keyframes cardIn {
      from {
        opacity: 0;
        transform: translateY(32px) scale(.97);
      }

      to {
        opacity: 1;
        transform: none;
      }
    }

    .panel-deco {
      width: 360px;
      flex-shrink: 0;
      background: var(--panel-grad);
      padding: 3rem 2.4rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow: hidden;
      transition: background .4s;
    }

    .deco-ring {
      position: absolute;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, .12);
    }

    .deco-ring:nth-child(1) {
      width: 280px;
      height: 280px;
      top: -80px;
      right: -80px;
    }

    .deco-ring:nth-child(2) {
      width: 180px;
      height: 180px;
      top: -20px;
      right: -20px;
    }

    .deco-ring:nth-child(3) {
      width: 340px;
      height: 340px;
      bottom: -120px;
      left: -120px;
    }

    .deco-top {
      position: relative;
      z-index: 1;
    }

    .deco-headline {
      font-family: 'Playfair Display', serif;
      font-size: 1.9rem;
      font-weight: 900;
      color: #fff;
      line-height: 1.2;
      margin-bottom: .9rem;
    }

    .deco-headline em {
      font-style: italic;
      opacity: .88;
    }

    .deco-sub {
      font-size: .88rem;
      color: rgba(255, 255, 255, .75);
      line-height: 1.7;
    }

    .deco-testimonials {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      gap: .8rem;
    }

    .tcard {
      background: rgba(255, 255, 255, .12);
      border: 1px solid rgba(255, 255, 255, .18);
      border-radius: 14px;
      padding: .9rem 1rem;
      backdrop-filter: blur(10px);
      transition: transform .3s;
    }

    .tcard:hover {
      transform: translateX(4px);
    }

    .tcard-top {
      display: flex;
      align-items: center;
      gap: .6rem;
      margin-bottom: .4rem;
    }

    .tcard-avatar {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: rgba(255, 255, 255, .3);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .72rem;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
    }

    .tcard-name {
      font-size: .78rem;
      font-weight: 700;
      color: #fff;
    }

    .tcard-stars {
      font-size: .7rem;
      color: #fbbf24;
      margin-left: auto;
    }

    .tcard-text {
      font-size: .78rem;
      color: rgba(255, 255, 255, .82);
      line-height: 1.5;
      font-style: italic;
    }

    .deco-bottom {
      position: relative;
      z-index: 1;
    }

    .deco-stats {
      display: flex;
      gap: 1.5rem;
    }

    .ds {
      display: flex;
      flex-direction: column;
    }

    .ds-num {
      font-size: 1.2rem;
      font-weight: 800;
      color: #fff;
    }

    .ds-lbl {
      font-size: .7rem;
      color: rgba(255, 255, 255, .65);
    }

    .panel-form {
      flex: 1;
      background: var(--surface);
      padding: 3rem 2.8rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      transition: background .4s;
      position: relative;
    }

    .tabs {
      display: flex;
      background: var(--surface2);
      border-radius: 12px;
      padding: 4px;
      margin-bottom: 2.2rem;
      border: 1px solid var(--border);
    }

    .tab {
      flex: 1;
      padding: .55rem 1rem;
      border-radius: 9px;
      border: none;
      font-family: 'DM Sans', sans-serif;
      font-size: .9rem;
      font-weight: 600;
      cursor: pointer;
      transition: all .28s cubic-bezier(.22, 1, .36, 1);
      background: transparent;
      color: var(--text3);
    }

    .tab.active {
      background: var(--accent);
      color: #fff;
      box-shadow: 0 2px 14px var(--glow);
      transform: scale(1.02);
    }

    .form-view {
      display: none;
      flex-direction: column;
      gap: 1.15rem;
      animation: fadeSlide .32s ease both;
    }

    .form-view.active {
      display: flex;
    }

    @keyframes fadeSlide {
      from {
        opacity: 0;
        transform: translateY(12px);
      }

      to {
        opacity: 1;
        transform: none;
      }
    }

    .form-head {
      margin-bottom: .1rem;
    }

    .form-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.7rem;
      font-weight: 900;
      color: var(--text);
      margin-bottom: .25rem;
    }

    .form-sub {
      font-size: .88rem;
      color: var(--text3);
      line-height: 1.5;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: .32rem;
    }

    .field label {
      font-size: .8rem;
      font-weight: 600;
      color: var(--text2);
      letter-spacing: .02em;
    }

    .field-wrap {
      position: relative;
    }

    .field-icon {
      position: absolute;
      left: .9rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text3);
      pointer-events: none;
      display: flex;
      transition: color .2s;
    }

    .field-wrap:focus-within .field-icon {
      color: var(--accent);
    }

    .field input {
      width: 100%;
      padding: .75rem 1rem .75rem 2.6rem;
      border-radius: 11px;
      border: 1.5px solid var(--input-border);
      background: var(--input-bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: .92rem;
      outline: none;
      transition: border-color .2s, box-shadow .2s, background .4s;
    }

    .field input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3.5px var(--glow);
    }

    .field input::placeholder {
      color: var(--text3);
    }

    .field input.error {
      border-color: var(--error);
    }

    .field-err {
      font-size: .75rem;
      color: var(--error);
      display: none;
    }

    .field-err.show {
      display: block;
    }

    .eye {
      position: absolute;
      right: .85rem;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: var(--text3);
      display: flex;
      align-items: center;
      padding: 2px;
      transition: color .2s;
    }

    .eye:hover {
      color: var(--accent);
    }

    .field-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .8rem;
    }

    .row-between {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .check-label {
      display: flex;
      align-items: center;
      gap: .5rem;
      font-size: .82rem;
      color: var(--text2);
      cursor: pointer;
      user-select: none;
    }

    .check-label input {
      accent-color: var(--accent);
      width: 15px;
      height: 15px;
      cursor: pointer;
    }

    .forgot {
      font-size: .82rem;
      color: var(--accent);
      text-decoration: none;
      font-weight: 500;
    }

    .forgot:hover {
      text-decoration: underline;
    }

    .btn-submit {
      width: 100%;
      padding: .88rem;
      border-radius: 12px;
      border: none;
      background: var(--accent);
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      letter-spacing: .02em;
      box-shadow: 0 4px 20px var(--glow);
      transition: opacity .2s, transform .18s, box-shadow .2s, background .3s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: .5rem;
      position: relative;
      overflow: hidden;
    }

    .btn-submit::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, .15), transparent);
      transform: translateX(-100%);
      transition: transform .6s;
    }

    .btn-submit:hover::after {
      transform: translateX(100%);
    }

    .btn-submit:hover {
      opacity: .9;
      transform: translateY(-1px);
      box-shadow: 0 8px 32px var(--glow);
    }

    .btn-submit:active {
      transform: none;
    }

    .btn-submit.loading {
      opacity: .7;
      pointer-events: none;
    }

    .btn-submit.done {
      background: var(--success);
      pointer-events: none;
    }

    .divider {
      display: flex;
      align-items: center;
      gap: .75rem;
      font-size: .78rem;
      color: var(--text3);
    }

    .divider::before,
    .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .social-row {
      display: flex;
      gap: .7rem;
    }

    .btn-social {
      flex: 1;
      padding: .62rem .5rem;
      border-radius: 10px;
      border: 1.5px solid var(--border);
      background: var(--input-bg);
      color: var(--text2);
      font-family: 'DM Sans', sans-serif;
      font-size: .83rem;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: .45rem;
      transition: border-color .2s, background .2s, color .2s, transform .15s;
    }

    .btn-social:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--surface2);
      transform: translateY(-1px);
    }

    .form-foot {
      text-align: center;
      font-size: .84rem;
      color: var(--text3);
    }

    .form-foot a {
      color: var(--accent);
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      border-bottom: 1px solid transparent;
      transition: border-color .2s;
    }

    .form-foot a:hover {
      border-color: var(--accent);
    }

    .strength-wrap {
      display: flex;
      flex-direction: column;
      gap: .25rem;
      margin-top: -.1rem;
    }

    .strength-bars {
      display: flex;
      gap: 4px;
    }

    .sbar {
      flex: 1;
      height: 3px;
      border-radius: 3px;
      background: var(--border);
      transition: background .3s;
    }

    .sbar.w {
      background: var(--error);
    }

    .sbar.m {
      background: #d97706;
    }

    .sbar.s {
      background: var(--success);
    }

    .strength-text {
      font-size: .72rem;
      color: var(--text3);
    }

    @media (max-width: 700px) {
      .panel-deco {
        display: none;
      }

      .panel-form {
        padding: 2rem 1.5rem;
      }

      .auth-card {
        max-width: 420px;
        border-radius: 20px;
      }

      .field-row {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>

  <div class="ambient">
    <div class="amb-orb"></div>
    <div class="amb-orb"></div>
    <div class="amb-orb"></div>
  </div>

  <nav class="topbar">
    <a class="logo" href="bookly.html">Book<span>ly</span></a>
    <div class="topbar-right">
      <a class="back-link" href="bookly.html">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
          <polyline points="15 18 9 12 15 6" />
        </svg>
        Back to home
      </a>
      <button class="theme-btn" onclick="toggleTheme()">
      <svg id="theme-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
    </button>
    </div>
  </nav>

  <div class="page">
    <div class="auth-card">
      <div class="panel-deco">
        <div class="deco-ring"></div>
        <div class="deco-ring"></div>
        <div class="deco-ring"></div>

        <div class="deco-top">
          <div class="deco-headline">Good to have you <em>back.</em></div>
          <div class="deco-sub">Your bookshelf, your community, your stories — all right where you left them.</div>
        </div>

        <div class="deco-testimonials">
          <div class="tcard">
            <div class="tcard-top">
              <div class="tcard-avatar">N</div>
              <div class="tcard-name">noel_writes</div>
              <div class="tcard-stars">★★★★★</div>
            </div>
            <div class="tcard-text">"I write books in this site for some reason..."</div>
          </div>
          <div class="tcard">
            <div class="tcard-top">
              <div class="tcard-avatar" style="background:rgba(255,255,255,.4)">M</div>
              <div class="tcard-name">miguel</div>
              <div class="tcard-stars">★★★★★</div>
            </div>
            <div class="tcard-text">"Omg Noel is sooo cool."</div>
          </div>
        </div>

        <div class="deco-bottom">
          <div class="deco-stats">
            <div class="ds"><span class="ds-num">2M+</span><span class="ds-lbl">Stories</span></div>
            <div class="ds"><span class="ds-num">500K+</span><span class="ds-lbl">Writers</span></div>
            <div class="ds"><span class="ds-num">12M+</span><span class="ds-lbl">Readers</span></div>
          </div>
        </div>
      </div>

      <div class="panel-form">
        <div class="tabs">
          <button class="tab active" id="tab-login" onclick="switchTab('login')">Log in</button>
          <button class="tab" id="tab-signup" onclick="switchTab('signup')">Create account</button>
        </div>

        <div class="form-view active" id="view-login">
          <div class="form-head">
            <div class="form-title">Welcome back 👋</div>
            <div class="form-sub">Your stories have missed you. Let's pick up where you left off.</div>
          </div>

          <div class="field">
            <label for="li-id">Email or username</label>
            <div class="field-wrap">
              <span class="field-icon">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </span>
              <input type="text" id="li-id" placeholder="ada@example.com or inkwitch99" autocomplete="username">
              <div class="field-err" id="li-id-err">Please enter your email or username.</div>
            </div>
          </div>

          <div class="field">
            <label for="li-pass">Password</label>
            <div class="field-wrap">
              <span class="field-icon">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </span>
              <input type="password" id="li-pass" placeholder="Your password" autocomplete="current-password">
              <button class="eye" type="button" onclick="toggleEye('li-pass',this)" title="Show/hide">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
            </div>
            <div class="field-err" id="li-pass-err">Please enter your password.</div>
          </div>

          <div class="row-between">
            <label class="check-label">
            <input type="checkbox" id="li-remember">
            Keep me logged in
          </label>
            <a href="#" class="forgot">Forgot password?</a>
          </div>

          <button class="btn-submit" id="li-btn" onclick="handleLogin()">
          <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
          Log in to Bookly
        </button>

          <div class="divider">or continue with</div>

          <div class="social-row">
            <button class="btn-social">
            <svg width="16" height="16" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Google
          </button>
            <button class="btn-social">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook
          </button>
            <button class="btn-social">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.257 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X / Twitter
          </button>
          </div>

          <div class="form-foot">New to Bookly? <a onclick="switchTab('signup')">Create a free account</a></div>
        </div>

        <div class="form-view" id="view-signup">
          <div class="form-head">
            <div class="form-title">Join Bookly ✨</div>
            <div class="form-sub">Free forever. No card needed. Just stories.</div>
          </div>

          <div class="field-row">
            <div class="field">
              <label for="su-fn">First name</label>
              <div class="field-wrap">
                <span class="field-icon">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </span>
                <input type="text" id="su-fn" placeholder="Ada">
              </div>
            </div>
            <div class="field">
              <label for="su-ln">Last name</label>
              <div class="field-wrap">
                <span class="field-icon">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </span>
                <input type="text" id="su-ln" placeholder="Lovelace">
              </div>
            </div>
          </div>

          <div class="field">
            <label for="su-user">Username</label>
            <div class="field-wrap">
              <span class="field-icon">
              <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/><path d="M21 21v-2a4 4 0 0 0-3-3.87"/></svg>
            </span>
              <input type="text" id="su-user" placeholder="inkwitch99" oninput="this.value=this.value.replace(/[^a-z0-9_]/gi,'').toLowerCase()">
            </div>
          </div>

          <div class="field">
            <label for="su-email">Email</label>
            <div class="field-wrap">
              <span class="field-icon">
              <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </span>
              <input type="email" id="su-email" placeholder="ada@example.com">
            </div>
          </div>

          <div class="field">
            <label for="su-pass">Password</label>
            <div class="field-wrap">
              <span class="field-icon">
              <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </span>
              <input type="password" id="su-pass" placeholder="Min. 8 characters" oninput="checkStrength(this.value)">
              <button class="eye" type="button" onclick="toggleEye('su-pass',this)">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
            </div>
            <div class="strength-wrap">
              <div class="strength-bars">
                <div class="sbar" id="sb1"></div>
                <div class="sbar" id="sb2"></div>
                <div class="sbar" id="sb3"></div>
                <div class="sbar" id="sb4"></div>
              </div>
              <div class="strength-text" id="stext">Enter a password</div>
            </div>
          </div>

          <label class="check-label" style="font-size:.81rem">
          <input type="checkbox" id="su-terms">
          I agree to Bookly's <a href="#" style="color:var(--accent);font-weight:600;text-decoration:none">Terms</a> &amp; <a href="#" style="color:var(--accent);font-weight:600;text-decoration:none">Privacy Policy</a>
        </label>

          <button class="btn-submit" id="su-btn" onclick="handleSignup()">
          <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          Create my account
        </button>

          <div class="divider">or sign up with</div>
          <div class="social-row">
            <button class="btn-social">
            <svg width="16" height="16" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Google
          </button>
            <button class="btn-social">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook
          </button>
            <button class="btn-social">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.257 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X / Twitter
          </button>
          </div>

          <div class="form-foot">Already have an account? <a onclick="switchTab('login')">Log in</a></div>
        </div>

      </div>
    </div>
  </div>

  <script>
  function switchTab(tab) {
    ['login','signup'].forEach(t => {
      document.getElementById('tab-'+t).classList.toggle('active', t === tab);
      document.getElementById('view-'+t).classList.toggle('active', t === tab);
    });
  }

  function toggleTheme() {
    const html = document.documentElement;
    const dark = html.getAttribute('data-theme') === 'dark';
    html.setAttribute('data-theme', dark ? 'light' : 'dark');
    document.getElementById('theme-icon').innerHTML = dark
      ? `<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>`
      : `<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>`;
  }

  function toggleEye(id, btn) {
    const inp = document.getElementById(id);
    const show = inp.type === 'password';
    inp.type = show ? 'text' : 'password';
    btn.innerHTML = show
      ? `<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`
      : `<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`;
  }

  function checkStrength(v) {
    const bars = ['sb1','sb2','sb3','sb4'].map(id => document.getElementById(id));
    const txt  = document.getElementById('stext');
    bars.forEach(b => b.className = 'sbar');
    if (!v) { txt.textContent = 'Enter a password'; txt.style.color = ''; return; }
    let s = 0;
    if (v.length >= 8)          s++;
    if (/[A-Z]/.test(v))        s++;
    if (/[0-9]/.test(v))        s++;
    if (/[^A-Za-z0-9]/.test(v)) s++;
    const cls = s <= 1 ? 'w' : s <= 2 ? 'm' : 's';
    const labels = ['','Weak','Fair','Good','Strong'];
    const colors = { w:'var(--error)', m:'#d97706', s:'var(--success)' };
    for (let i = 0; i < s; i++) bars[i].classList.add(cls);
    txt.textContent = labels[s];
    txt.style.color = colors[cls];
  }

  function handleLogin() {
    const id   = document.getElementById('li-id');
    const pass = document.getElementById('li-pass');
    const idErr   = document.getElementById('li-id-err');
    const passErr = document.getElementById('li-pass-err');
    let ok = true;

    if (!id.value.trim()) {
      id.classList.add('error'); idErr.classList.add('show'); ok = false;
    } else { id.classList.remove('error'); idErr.classList.remove('show'); }

    if (!pass.value) {
      pass.classList.add('error'); passErr.classList.add('show'); ok = false;
    } else { pass.classList.remove('error'); passErr.classList.remove('show'); }

    if (!ok) return;

    const btn = document.getElementById('li-btn');
    btn.classList.add('loading');
    btn.innerHTML = `<svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24" style="animation:spin 1s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Logging in…`;

    setTimeout(() => {
      btn.classList.remove('loading');
      btn.classList.add('done');
      btn.innerHTML = `<svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Welcome back!`;
      setTimeout(() => {
        btn.classList.remove('done');
        btn.innerHTML = `<svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg> Log in to Bookly`;
      }, 2500);
    }, 1500);
  }

  function handleSignup() {
    const btn = document.getElementById('su-btn');
    btn.classList.add('loading');
    btn.innerHTML = `<svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24" style="animation:spin 1s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Creating account…`;
    setTimeout(() => {
      btn.classList.remove('loading');
      btn.classList.add('done');
      btn.innerHTML = `<svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Account created!`;
      setTimeout(() => {
        btn.classList.remove('done');
        btn.innerHTML = `<svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg> Create my account`;
      }, 2500);
    }, 1500);
  }

  const style = document.createElement('style');
  style.textContent = `@keyframes spin { to { transform: rotate(360deg); } }`;
  document.head.appendChild(style);
  </script>
</body>

</html>
